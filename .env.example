# VibeFlow Analytics API Key
# Replace with your actual Gemini API Key from Google AI Studio.
VITE_GEMINI_API_KEY="your_api_key_here"

# (Future Integration) Google Cloud BigQuery Analytics Config
VITE_BIGQUERY_PROJECT_ID="your_project_id"
VITE_BIGQUERY_DATASET="event_analytics_dataset"

# Peer-To-Peer Networking Signaling Server
# (Optional: Only if circumventing native WebSocket fallback)
VITE_P2P_SIGNAL_URL="your_signaling_url"
